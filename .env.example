# =================================================================
# LiveCaptions 环境变量配置示例
# 请复制此文件为 .env 并根据实际情况修改配置
# =================================================================

# --- LLM 服务配置 (用于翻译与文本处理) ---
# OpenAI 或 兼容接口 (如 豆包 Ark) 的 API 密钥
OPENAI_API_KEY=your-api-key-here
# LLM 服务的 API 基础地址
OPENAI_BASE_URL=https://api.openai.com/v1/
# 使用的 LLM 模型名称 (例如: gpt-4o, doubao-pro-128k)
LLM_MODEL=gpt-4o

# --- 基础设施与数据库配置 ---
# 数据库连接 URL (默认使用 SQLite)
DATABASE_URL=sqlite:///./data/tasks.db
# Redis 连接地址 (用于 Celery 消息代理和 WebSocket)
REDIS_URL=redis://localhost:6379/0
# Celery 消息代理地址 (通常与 REDIS_URL 一致)
CELERY_BROKER_URL=redis://localhost:6379/0
# Celery 结果存储地址
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Celery 时区设置
CELERY_TIMEZONE=Asia/Shanghai

# --- AI 模型配置 ---
# HuggingFace Token (访问私有或限制模型时使用)
HF_TOKEN=your-huggingface-token-here
# HuggingFace 缓存与模型存放目录
HF_HOME=./models/huggingface
# 是否启用 HuggingFace 离线模式
HF_HUB_OFFLINE=1
# PyTorch/Torch Hub 模型存放目录
TORCH_HOME=./models/torch
# Faster-Whisper v2 ASR 模型路径或名称
WHISPER_MODEL_V2_PATH=./models/faster-whisper/large-v2
# Faster-Whisper v3 ASR 模型路径或名称
WHISPER_MODEL_V3_PATH=./models/faster-whisper/large-v3

# --- Demucs 人声分离配置 ---
# Demucs 模型名称
DEMUCS_MODEL=htdemucs_ft
# Demucs 设备 (cuda 或 cpu)
DEMUCS_DEVICE=cuda
# Demucs 分段长度 (秒)，用于控制内存占用
DEMUCS_SEGMENT=7
# Demucs shifts 数量，影响分离质量和速度 (值越大质量越好但越慢)
DEMUCS_SHIFTS=2

# --- 文件系统配置 ---
# 上传原始视频存放目录
UPLOAD_DIR=./data/uploads
# 任务处理中间结果与最终文件存放目录
RESULT_DIR=./data/results

# --- 服务器配置 ---
# FastAPI 服务监听地址
HOST=0.0.0.0
# FastAPI 服务监听端口
PORT=8000
